# ============================================================
# TRANCHI AI — Environment Variables
# Copy to .env and fill in. Start with just EMAIL + ANTHROPIC + SUPABASE.
# ============================================================

# ── REQUIRED TO START ────────────────────────────────────────

# Supabase (supabase.com → Project Settings → API)
SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_KEY=your_service_role_key_here

# Anthropic — Claude 3.5 Sonnet underwriter (console.anthropic.com)
ANTHROPIC_API_KEY=sk-ant-...

# Gmail SMTP — free email outreach (no Twilio needed to start)
# Setup: Google Account → Security → App Passwords → Mail → Generate
EMAIL_ADDRESS=your@gmail.com
EMAIL_APP_PASSWORD=xxxx xxxx xxxx xxxx
REPLY_TO_EMAIL=your@gmail.com

# Your timezone for Google Meet scheduling
YOUR_TIMEZONE=America/Chicago
YOUR_EMAIL=your@gmail.com

# ── ADD LATER (when ready to send SMS) ───────────────────────

# Twilio (twilio.com → Console)
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_auth_token
TWILIO_FROM_NUMBER=+1XXXXXXXXXX

# ── OPTIONAL (enhances scraping volume) ──────────────────────

# Apify — fallback scraper (apify.com → Settings → Integrations)
APIFY_API_TOKEN=apify_api_...

# BatchData — property comps (batchdata.com → API Keys)
BATCHDATA_API_KEY=your_batchdata_key
