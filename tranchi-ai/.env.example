# ============================================================
# TRANCHI AI — Environment Variables
# Copy to .env and fill in all values
# ============================================================

# Supabase (supabase.com → Project Settings → API)
SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_KEY=your_service_role_key_here

# Anthropic — Claude 3.5 Sonnet (console.anthropic.com → API Keys)
ANTHROPIC_API_KEY=sk-ant-...

# Twilio — SMS outreach (twilio.com → Console)
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_auth_token
TWILIO_FROM_NUMBER=+1XXXXXXXXXX

# Apify — auction + buyer scraping (apify.com → Settings → Integrations)
APIFY_API_TOKEN=apify_api_...

# BatchData — property comps + enrichment (batchdata.com)
BATCHDATA_API_KEY=your_batchdata_key

# Google Calendar — for auto Google Meet booking
# Download service account JSON from Google Cloud Console
# IAM → Service Accounts → Create → Download JSON → save as google_credentials.json
GOOGLE_CALENDAR_ID=primary
YOUR_EMAIL=you@youremail.com
YOUR_TIMEZONE=America/Chicago
